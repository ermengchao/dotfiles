[Unit]
Description=Cross-platform cipboard syncing, history management tool

[Service]
Restart=on-failure

[Container]
ContainerName=syncclipboard-server
Image=docker.io/jericx/syncclipboard-server:latest
AutoUpdate=registry

Environment=SYNCCLIPBOARD_USERNAME=chao
Environment=SYNCCLIPBOARD_PASSWORD={{ gopass "chao/password" }}

PublishPort={{ .ports.syncclipboard_server }}:5033

Volume={{ env "XDG_DATA_HOME" }}/syncclipboard-server:/app/data
