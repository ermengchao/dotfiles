[Unit]
Description=Auto Bangumi Container

[Service]
Restart=on-failure

[Container]
ContainerName=auto_bangumi
Image=ghcr.io/estrellaxd/auto_bangumi:latest
AutoUpdate=registry

UserNS=keep-id
Entrypoint=/entry-host.sh

Environment=TZ=Asia/Shanghai
Environment=UMASK=022

PublishPort={{ .ports.auto_bangumi }}:{{ .ports.auto_bangumi }}

Volume={{ env "XDG_CONFIG_HOME" }}/auto_bangumi/entry-host.sh:/entry-host.sh:ro
Volume={{ env "XDG_CONFIG_HOME" }}/auto_bangumi:/app/config
Volume={{ env "XDG_DATA_HOME" }}/auto_bangumi:/app/data
