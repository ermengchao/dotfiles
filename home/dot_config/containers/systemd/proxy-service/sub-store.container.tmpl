[Unit]
Description=sub-store

[Service]
Restart=on-failure

[Container]
ContainerName=sub-store
Image=docker.io/xream/sub-store:http-meta
AutoUpdate=registry

Environment=SUB_STORE_BACKEND_API_HOST=0.0.0.0
Environment=SUB_STORE_BACKEND_API_PORT={{ .ports.sub_store.backend_api }}
Environment=SUB_STORE_BACKEND_MERGE=true
Environment=SUB_STORE_FRONTEND_BACKEND_PATH={{ gopass "sub_store/frontend_backend_path" }}
Environment=HOST=127.0.0.1

PublishPort={{ .ports.sub_store.backend_api }}:{{ .ports.sub_store.backend_api }}

Volume={{ env "XDG_DATA_HOME" }}/sub-store:/opt/app/data
