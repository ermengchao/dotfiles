[Unit]
Description=Logout then login campus network (05:00 daily via timer)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot

Environment=CNC_USER_ID={{ gopass "cnc/zc/user_id" | quote }}
Environment=CNC_PASSWORD={{ gopass "cnc/zc/password" | quote }}
Environment=CNC_SERVICE={{ gopass "cnc/zc/service" | quote }}
ExecStartPre=/home/chao/.local/bin/cnc logout
ExecStart=/usr/bin/sleep 2
ExecStartPost=/home/chao/.local/bin/cnc login

StandardOutput=journal
StandardError=journal
