#!/usr/bin/env fish

if type -q sing-box
  if {{ .meta.isProxyServer }}
    printf "🧑‍💻 Updating DNS record for sing-box...\n"

    set zone_name "er-meng.com"
    set record_name "{{ .meta.hostname }}.proxy.er-meng.com"
    set token {{ gopass "cloudflare/token" | quote }}

    set imds_token (curl -fsS -X PUT \
      "http://169.254.169.254/latest/api/token" \
      -H "X-aws-ec2-metadata-token-ttl-seconds: 21600")

    if test -z "$imds_token"
      printf "‼️ Could not get EC2 IMDSv2 token.\n" >&2
      exit 1
    end

    set ip (curl -fsS \
      -H "X-aws-ec2-metadata-token: $imds_token" \
      "http://169.254.169.254/latest/meta-data/public-ipv4")

    if not string match -rq '^\d{1,3}(\.\d{1,3}){3}$' "$ip"
      printf "‼️ Invalid or empty EC2 public IPv4: $ip\n" >&2
      exit 1
    end

    set zone_resp (curl -sS \
      -H "Authorization: Bearer $token" \
      -H "Content-Type: application/json" \
      "https://api.cloudflare.com/client/v4/zones?name=$zone_name")

    set zone_id (echo "$zone_resp" | jq -r '.result[0].id // empty')

    if test -z "$zone_id"
      printf "‼️ Could not find Cloudflare zone: $zone_name\n" >&2
      echo "$zone_resp" | jq . >&2
      exit 1
    end

    set record_resp (curl -sS \
      -H "Authorization: Bearer $token" \
      -H "Content-Type: application/json" \
      "https://api.cloudflare.com/client/v4/zones/$zone_id/dns_records?type=A&name=$record_name")

    set record_id (echo "$record_resp" | jq -r '.result[0].id // empty')

    set payload (jq -nc \
      --arg type "A" \
      --arg name "$record_name" \
      --arg content "$ip" \
      '{type:$type,name:$name,content:$content,ttl:60,proxied:false}')

    if test -n "$record_id"
      set cf_resp (curl -sS -X PUT \
        -H "Authorization: Bearer $token" \
        -H "Content-Type: application/json" \
        --data "$payload" \
        "https://api.cloudflare.com/client/v4/zones/$zone_id/dns_records/$record_id")
    else
      set cf_resp (curl -sS -X POST \
        -H "Authorization: Bearer $token" \
        -H "Content-Type: application/json" \
        --data "$payload" \
        "https://api.cloudflare.com/client/v4/zones/$zone_id/dns_records")
    end

    if test (echo "$cf_resp" | jq -r '.success') != "true"
      printf "‼️ Cloudflare DNS update failed.\n" >&2
      echo "$cf_resp" | jq . >&2
      exit 1
    end

    printf "✅ Done.\n"
  end
end
