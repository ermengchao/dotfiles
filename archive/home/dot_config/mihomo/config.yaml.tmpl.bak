proxies:
  - name: "🟢 Direct"
    type: direct
  - name: "🔴 Reject"
    type: reject

proxy-groups:
  - name: "🌐 Proxy"
    type: select
    proxies:
      - "⚡️ Auto"
      - "🇭🇰 HK"
      - "🇹🇼 TW"
      - "🇯🇵 JP"
      - "🇸🇬 SG"
      - "🇺🇸 US"
      - "🇲🇾 MY"
      - "🇦🇷 AR"
      - "🇹🇷 TR"
  - name: "⚡️ Auto"
    type: url-test
    use:
      - 🏳️‍🌈 General
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  - name: "🧠 AI"
    type: select
    proxies:
      - "🌐 Proxy"
      - "🟢 Direct"
      - "⚡️ Auto"
      - "🇹🇼 TW"
      - "🇯🇵 JP"
      - "🇸🇬 SG"
      - "🇺🇸 US"
      - "🇲🇾 MY"
      - "🇦🇷 AR"
      - "🇹🇷 TR"
  - name: "🎮 Game"
    type: select
    proxies:
      - "🌐 Proxy"
      - "🟢 Direct"
      - "⚡️ Auto"
      - "🇭🇰 HK"
      - "🇹🇼 TW"
      - "🇯🇵 JP"
      - "🇸🇬 SG"
      - "🇺🇸 US"
      - "🇲🇾 MY"
      - "🇦🇷 AR"
      - "🇹🇷 TR"
  - name: "📺 Media"
    type: select
    proxies:
      - "🌐 Proxy"
      - "🟢 Direct"
      - "⚡️ Auto"
      - "🇭🇰 HK"
      - "🇹🇼 TW"
      - "🇯🇵 JP"
      - "🇸🇬 SG"
      - "🇺🇸 US"
      - "🇲🇾 MY"
      - "🇦🇷 AR"
      - "🇹🇷 TR"
  - name: "🐟 Final"
    type: select
    proxies:
      - "🌐 Proxy"
      - "🟢 Direct"
      - "⚡️ Auto"
      - "🇭🇰 HK"
      - "🇹🇼 TW"
      - "🇯🇵 JP"
      - "🇸🇬 SG"
      - "🇺🇸 US"
      - "🇲🇾 MY"
      - "🇦🇷 AR"
      - "🇹🇷 TR"
  - name: "🇭🇰 HK"
    type: url-test
    use:
      - 🇭🇰 HK
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  - name: "🇹🇼 TW"
    type: url-test
    use:
      - 🇹🇼 TW
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  - name: "🇯🇵 JP"
    type: url-test
    use:
      - 🇯🇵 JP
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  - name: "🇸🇬 SG"
    type: url-test
    use:
      - 🇸🇬 SG
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  - name: "🇺🇸 US"
    type: url-test
    use:
      - 🇺🇸 US
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  - name: "🇲🇾 MY"
    type: url-test
    use:
      - 🇲🇾 MY
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  - name: "🇦🇷 AR"
    type: url-test
    use:
      - 🇦🇷 AR
    url: "https://www.gstatic.com/generate_204"
    interval: 300
  - name: "🇹🇷 TR"
    type: url-test
    use:
      - 🇹🇷 TR
    url: "https://www.gstatic.com/generate_204"
    interval: 300

rules:
  # 🚫 AD
  - RULE-SET,advertising,🔴 Reject
  - RULE-SET,zhihu_ads,🔴 Reject
  - RULE-SET,hijacking,🔴 Reject
  - RULE-SET,privacy,🔴 Reject

  # 🧠 AI
  - RULE-SET,ai_chao,🧠 AI
  - RULE-SET,claude,🧠 AI
  - RULE-SET,copilot,🧠 AI
  - RULE-SET,gemini,🧠 AI
  - RULE-SET,openai,🧠 AI

  # 🟢 Direct
  - RULE-SET,direct_chao,🟢 Direct
  - RULE-SET,apple,🟢 Direct
  - RULE-SET,china_max,🟢 Direct
  - RULE-SET,download,🟢 Direct
  - RULE-SET,lan,🟢 Direct

  # 🎮 Game
  - RULE-SET,game_chao,🎮 Game
  - RULE-SET,game,🎮 Game

  # 📺 Media
  - RULE-SET,disney,📺 Media
  - RULE-SET,netflix,📺 Media
  - RULE-SET,hbo_usa,📺 Media
  - RULE-SET,spotify,📺 Media
  - RULE-SET,tiktok,📺 Media
  - RULE-SET,youtube,📺 Media
  - RULE-SET,youtube_music,📺 Media

  # 🌐 Proxy
  - RULE-SET,proxy_chao,🌐 Proxy
  - RULE-SET,developer,🌐 Proxy
  - RULE-SET,google,🌐 Proxy
  - RULE-SET,github,🌐 Proxy

  # IP
  - GEOIP, CN, 🟢 Direct
  - RULE-SET,amazon_cloud,🌐 Proxy, no-resolve

  - MATCH,🐟 Final

